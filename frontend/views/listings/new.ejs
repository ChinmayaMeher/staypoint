<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StayPoint - Add New Listing</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
  </head>
  <body>
    <%- include('../includes/navbar.ejs') %>

    <div class="flash-container">
      <% if (success && success.length) { %>
      <div class="flash flash-success">
        <i class="fa fa-check-circle"></i> <%= success %>
        <button class="flash-close" onclick="this.parentElement.remove()">
          ×
        </button>
      </div>
      <% } %> <% if (error && error.length) { %>
      <div class="flash flash-error">
        <i class="fa fa-exclamation-circle"></i> <%= error %>
        <button class="flash-close" onclick="this.parentElement.remove()">
          ×
        </button>
      </div>
      <% } %>
    </div>

    <main>
      <div class="form-page">
        <div class="form-card">
          <div class="form-card-header">
            <h2><i class="fa fa-plus-circle"></i> List Your Room</h2>
            <p>Share your space with travelers from around the world</p>
          </div>

          <form action="/listings" method="POST" class="listing-form" enctype="multipart/form-data">
            <input type="hidden" name="_token" value="<%= csrfToken %>" />
            <div class="form-grid">
              <div class="form-group span-2">
                <label for="title">Listing Title *</label>
                <input
                  type="text"
                  id="title"
                  name="listing[title]"
                  class="form-control"
                  placeholder="e.g. Cozy Studio in Bandra West"
                  required
                />
              </div>

              <div class="form-group span-2">
                <label for="description">Description</label>
                <textarea
                  id="description"
                  name="listing[description]"
                  class="form-control"
                  rows="4"
                  placeholder="Describe your place — what makes it special?"
                ></textarea>
              </div>

              <div class="form-group span-2">
                <label>Listing Images *</label>
                <div class="image-upload-options" style="display: flex; gap: 20px; flex-wrap: wrap;">
                  <div style="flex: 1; min-width: 250px; padding: 15px; border: 1px dashed var(--border-color, #ccc); border-radius: 8px; background: var(--light-bg, #f8f9fa);">
                    <label for="images" style="display: block; margin-bottom: 8px;"><strong><i class="fa fa-upload"></i> Upload from Device</strong></label>
                    <input type="file" id="images" name="images" class="form-control" accept="image/*" multiple />
                    <small>Select up to 5 images (JPG, PNG)</small>
                  </div>
                  <div style="display: flex; align-items: center; font-weight: bold; color: var(--text-muted, #888);">OR</div>
                  <div style="flex: 1; min-width: 250px; padding: 15px; border: 1px dashed var(--border-color, #ccc); border-radius: 8px; background: var(--light-bg, #f8f9fa);">
                    <label for="image" style="display: block; margin-bottom: 8px;"><strong><i class="fa fa-link"></i> Paste Image URL</strong></label>
                    <input type="url" id="image" name="listing[image]" class="form-control" placeholder="https://images.unsplash.com/..." />
                    <small>Provide a link to an external image</small>
                  </div>
                </div>
              </div>

              <div class="form-group">
                <label for="price">Price per Night (₹) *</label>
                <input
                  type="number"
                  id="price"
                  name="listing[price]"
                  class="form-control"
                  placeholder="1500"
                  min="1"
                  required
                />
              </div>

              <div class="form-group">
                <label for="rooms">Number of Rooms *</label>
                <input
                  type="number"
                  id="rooms"
                  name="listing[rooms]"
                  class="form-control"
                  placeholder="1"
                  min="1"
                  value="1"
                  required
                />
              </div>

              <div class="form-group">
                <label for="category">Category *</label>
                <select
                  id="category"
                  name="listing[category]"
                  class="form-control"
                  required
                >
                  <option value="">Select type</option>
                  <option value="Apartment">Apartment</option>
                  <option value="House">House</option>
                  <option value="Villa">Villa</option>
                  <option value="Cabin">Cabin</option>
                  <option value="Studio">Studio</option>
                  <option value="Hostel">Hostel</option>
                </select>
              </div>

              <div class="form-group">
                <label for="location">City / Area *</label>
                <input
                  type="text"
                  id="location"
                  name="listing[location]"
                  class="form-control"
                  placeholder="e.g. Bandra West, Mumbai"
                  required
                />
              </div>

              <div class="form-group">
                <label for="country">Country *</label>
                <input
                  type="text"
                  id="country"
                  name="listing[country]"
                  class="form-control"
                  placeholder="e.g. India"
                  required
                />
              </div>

              <div class="form-group span-2">
                <label>Amenities</label>
                <div class="amenities-grid">
                  <label class="amenity-checkbox"><input type="checkbox" name="listing[amenities][]" value="WiFi"> <i class="fa fa-wifi"></i> WiFi</label>
                  <label class="amenity-checkbox"><input type="checkbox" name="listing[amenities][]" value="Air Conditioning"> <i class="fa fa-snowflake"></i> AC</label>
                  <label class="amenity-checkbox"><input type="checkbox" name="listing[amenities][]" value="Kitchen"> <i class="fa fa-utensils"></i> Kitchen</label>
                  <label class="amenity-checkbox"><input type="checkbox" name="listing[amenities][]" value="Parking"> <i class="fa fa-car"></i> Parking</label>
                  <label class="amenity-checkbox"><input type="checkbox" name="listing[amenities][]" value="Pool"> <i class="fa fa-swimming-pool"></i> Pool</label>
                  <label class="amenity-checkbox"><input type="checkbox" name="listing[amenities][]" value="TV"> <i class="fa fa-tv"></i> TV</label>
                  <label class="amenity-checkbox"><input type="checkbox" name="listing[amenities][]" value="Washer"> <i class="fa fa-jug-detergent"></i> Washer</label>
                  <label class="amenity-checkbox"><input type="checkbox" name="listing[amenities][]" value="Gym"> <i class="fa fa-dumbbell"></i> Gym</label>
                  <label class="amenity-checkbox"><input type="checkbox" name="listing[amenities][]" value="Heating"> <i class="fa fa-fire"></i> Heating</label>
                  <label class="amenity-checkbox"><input type="checkbox" name="listing[amenities][]" value="Workspace"> <i class="fa fa-laptop-house"></i> Workspace</label>
                </div>
              </div>
            </div>

            <div class="form-actions">
              <a href="/listings" class="btn btn-ghost">Cancel</a>
              <button type="submit" class="btn btn-primary">
                <i class="fa fa-plus"></i> Create Listing
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>

    <%- include('../includes/footer.ejs') %>
    <%- include('../includes/chatbot.ejs') %>
    <script src="/js/script.js"></script>
  </body>
</html>
