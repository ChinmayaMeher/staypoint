<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StayPoint - <%= listing.title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css?v=5" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
  </head>
  <body>
    <%- include('../includes/navbar.ejs') %>
    <div class="flash-container">
      <% if (success && success.length) { %>
      <div class="flash flash-success">
        <i class="fa fa-check-circle"></i> <%= success %><button
          class="flash-close"
          onclick="this.parentElement.remove()"
        >
          x
        </button>
      </div>
      <% } %> <% if (error && error.length) { %>
      <div class="flash flash-error">
        <i class="fa fa-exclamation-circle"></i> <%= error %><button
          class="flash-close"
          onclick="this.parentElement.remove()"
        >
          x
        </button>
      </div>
      <% } %>
    </div>
    <main>
      <div class="show-page">
        <div class="show-hero">
          <img
            src="<%= listing.image %>"
            alt="<%= listing.title %>"
            class="show-image"
          />
          <span class="show-category"><%= listing.category %></span>
        </div>

        <div class="show-content">
          <div class="show-main">
            <div class="show-header">
              <h1 class="show-title"><%= listing.title %></h1>
              <div class="show-meta">
                <span class="show-location">
                  <i class="fa fa-map-marker-alt"></i>
                  <%= listing.location %>, <%= listing.country %>
                </span>
                <span class="show-rooms">
                  <i class="fa fa-door-open"></i>
                  <%= listing.rooms %> Room<%= listing.rooms > 1 ? 's' : '' %>
                </span>
              </div>
            </div>

            <div class="show-description">
              <h3>About this place</h3>
              <p><%= listing.description || 'A wonderful place to stay!' %></p>
            </div>

            <% if (listing.amenities && listing.amenities.length) { %>
            <div class="show-amenities">
              <h3>Amenities</h3>
              <div class="amenities-grid">
                <% for (let a of listing.amenities) { %>
                <span class="amenity-tag"
                  ><i class="fa fa-check"></i> <%= a %></span
                >
                <% } %>
              </div>
            </div>
            <% } %>

            <div class="show-owner">
              <i class="fa fa-user-circle fa-2x"></i>
              <div>
                <p class="owner-label">Hosted by</p>
                <p class="owner-name">
                  <%= listing.owner ? listing.owner.username : 'StayPoint Host'
                  %>
                </p>
              </div>
            </div>

            <% if (currUser && listing.owner &&
            currUser._id.equals(listing.owner._id)) { %>
            <div class="owner-actions">
              <a
                href="/listings/<%= listing._id %>/edit"
                class="btn btn-outline"
              >
                <i class="fa fa-edit"></i> Edit Listing
              </a>
              <form
                action="/listings/<%= listing._id %>?_method=DELETE"
                method="POST"
                onsubmit="return confirm('Delete this listing?')"
              >
                <input type="hidden" name="_token" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-danger">
                  <i class="fa fa-trash"></i> Delete
                </button>
              </form>
            </div>
            <% } %>

            <div class="reviews-section">
              <h3>Guest Reviews (<%= listing.reviews.length %>)</h3>

              <% if (listing.reviews.length === 0) { %>
              <p class="no-reviews">No reviews yet. Be the first to review!</p>
              <% } else { %>
              <div class="reviews-list">
                <% for (let review of listing.reviews) { %>
                <div class="review-card">
                  <div class="review-header">
                    <div class="review-author">
                      <i class="fa fa-user-circle"></i>
                      <strong
                        ><%= review.author ? review.author.username : 'Guest'
                        %></strong
                      >
                    </div>
                    <div class="review-rating">
                      <% for (let i = 1; i <= 5; i++) { %>
                      <span
                        class="star <%= i <= review.rating ? 'filled' : '' %>"
                        >&#9733;</span
                      >
                      <% } %>
                    </div>
                  </div>
                  <p class="review-comment"><%= review.comment %></p>
                  <p class="review-date">
                    <%= new Date(review.createdAt).toLocaleDateString('en-IN',
                    {year:'numeric', month:'short', day:'numeric'}) %>
                  </p>
                  <% if (currUser && review.author &&
                  currUser._id.equals(review.author._id)) { %>
                  <form
                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                    method="POST"
                  >
                    <input type="hidden" name="_token" value="<%= csrfToken %>" />
                    <button type="submit" class="btn-text-danger">
                      <i class="fa fa-trash-alt"></i> Delete review
                    </button>
                  </form>
                  <% } %>
                </div>
                <% } %>
              </div>
              <% } %> <% if (currUser) { %>
              <div class="review-form-wrap">
                <h4>Leave a Review</h4>
                <form
                  action="/listings/<%= listing._id %>/reviews"
                  method="POST"
                  class="review-form"
                >
                  <input type="hidden" name="_token" value="<%= csrfToken %>" />
                  <div class="rating-input">
                    <label>Your Rating</label>
                    <div class="star-selector">
                      <input
                        type="radio"
                        id="star5"
                        name="review[rating]"
                        value="5"
                        required
                      />
                      <label for="star5">&#9733;</label>
                      <input
                        type="radio"
                        id="star4"
                        name="review[rating]"
                        value="4"
                      />
                      <label for="star4">&#9733;</label>
                      <input
                        type="radio"
                        id="star3"
                        name="review[rating]"
                        value="3"
                      />
                      <label for="star3">&#9733;</label>
                      <input
                        type="radio"
                        id="star2"
                        name="review[rating]"
                        value="2"
                      />
                      <label for="star2">&#9733;</label>
                      <input
                        type="radio"
                        id="star1"
                        name="review[rating]"
                        value="1"
                      />
                      <label for="star1">&#9733;</label>
                    </div>
                  </div>
                  <div class="form-group">
                    <textarea
                      name="review[comment]"
                      class="form-control"
                      rows="3"
                      placeholder="Share your experience..."
                      required
                    ></textarea>
                  </div>
                  <button type="submit" class="btn btn-primary">
                    Submit Review
                  </button>
                </form>
              </div>
              <% } else { %>
              <p class="login-prompt">
                <a href="/login">Login</a> to leave a review.
              </p>
              <% } %>
            </div>
          </div>

          <div class="show-sidebar">
            <div class="price-card">
              <p class="price-display">
                &#8377;<%= listing.price.toLocaleString() %> <span>/night</span>
              </p>
              <% if (currUser) { %>
              <!-- <button
                class="btn btn-primary btn-full"
                onclick="alert('Booking feature coming soon!')"
              >
                <i class="fa fa-calendar-check"></i> Book Now
              </button> -->
              <!-- Book Now Button -->
              <% if (currUser.role === 'host' || currUser.role === 'admin') { %>
                <button
                  type="button"
                  class="bm-btn"
                  onclick="alert('Please switch the profile to guest to book a stay.')"
                  style="max-width: 300px"
                >
                  🗓 Book Now
                </button>
              <% } else { %>
                <button
                  type="button"
                  class="bm-btn"
                  onclick="openBookingModal()"
                  style="max-width: 300px"
                >
                  🗓 Book Now
                </button>
              <% } %>

              <% } else { %>
              <a href="/login" class="btn btn-primary btn-full"
                >Login to Book</a
              >
              <% } %>
              <ul class="price-details">
                <li>
                  <span>Rooms available</span><span><%= listing.rooms %></span>
                </li>
                <li>
                  <span>Category</span><span><%= listing.category %></span>
                </li>
                <li>
                  <span>Reviews</span><span><%= listing.reviews.length %></span>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <div class="back-link-wrap">
          <a href="/listings" class="btn btn-ghost">
            <i class="fa fa-arrow-left"></i> Back to all listings
          </a>
        </div>
      </div>
    </main>

    <% if (currUser) { %>
    <style>
      .booking-overlay.open {
        display: flex !important;
      }
    </style>
    <!-- ===== BOOKING MODAL ===== -->
    <div
      class="booking-overlay"
      id="bookingOverlay"
      data-listing-id="<%= listing._id %>"
      data-price="<%= listing.price %>"
      style="z-index: 99999 !important;"
    >
      <div class="booking-modal">
        <div class="bm-header">
          <span class="bm-title" id="bmTitle">Book your stay</span>
          <button class="bm-close" onclick="closeBookingModal()">✕</button>
        </div>

        <!-- Steps indicator -->
        <div class="bm-steps" id="bmSteps">
          <div class="bm-step active" id="bmS1">
            <div class="bm-step-dot">1</div>
            Dates
          </div>
          <div class="bm-step" id="bmS2">
            <div class="bm-step-dot">2</div>
            Guests
          </div>
          <div class="bm-step" id="bmS3">
            <div class="bm-step-dot">3</div>
            Confirm
          </div>
        </div>

        <!-- Panel 1: Dates -->
        <div class="bm-panel active" id="bmPanel1">
          <p class="bm-label">Select dates</p>
          <div class="bm-date-row">
            <div class="bm-date-field">
              <label>Check-in</label>
              <input type="date" id="bmCheckin" onchange="bmUpdateDates()" />
            </div>
            <div class="bm-date-field">
              <label>Check-out</label>
              <input type="date" id="bmCheckout" onchange="bmUpdateDates()" />
            </div>
          </div>
          <div class="bm-nights-line">
            <span id="bmNightsLabel">Select dates to see nights</span>
            <span id="bmNightsPrice"></span>
          </div>
          <p class="bm-status err" id="bmDateErr"></p>
          <button
            class="bm-next-btn"
            id="bmNextTo2"
            onclick="bmShowPanel(2)"
            disabled
            style="width: 100%; padding: 12px"
          >
            Next: Guests →
          </button>
        </div>

        <!-- Panel 2: Guests -->
        <div class="bm-panel" id="bmPanel2">
          <p class="bm-label">Who's coming?</p>
          <div class="bm-guest-row">
            <div>
              <div class="bm-guest-name">Adults</div>
              <div class="bm-guest-hint">Ages 13+</div>
            </div>
            <div class="bm-counter">
              <button class="bm-cnt-btn" id="bmAdultMinus" onclick="bmCount('adult',-1)" disabled>−</button>
              <span class="bm-cnt-val" id="bmAdultCount">1</span>
              <button class="bm-cnt-btn" id="bmAdultPlus" onclick="bmCount('adult',1)">+</button>
            </div>
          </div>
          <div class="bm-guest-row">
            <div>
              <div class="bm-guest-name">Children</div>
              <div class="bm-guest-hint">Ages 2–12</div>
            </div>
            <div class="bm-counter">
              <button class="bm-cnt-btn" id="bmChildMinus" onclick="bmCount('child',-1)" disabled>−</button>
              <span class="bm-cnt-val" id="bmChildCount">0</span>
              <button class="bm-cnt-btn" id="bmChildPlus" onclick="bmCount('child',1)">+</button>
            </div>
          </div>
          <div class="bm-guest-row">
            <div>
              <div class="bm-guest-name">Infants</div>
              <div class="bm-guest-hint">Under 2</div>
            </div>
            <div class="bm-counter">
              <button class="bm-cnt-btn" id="bmInfantMinus" onclick="bmCount('infant',-1)" disabled>−</button>
              <span class="bm-cnt-val" id="bmInfantCount">0</span>
              <button class="bm-cnt-btn" id="bmInfantPlus" onclick="bmCount('infant',1)">+</button>
            </div>
          </div>
          <div class="bm-nav-row">
            <button class="bm-back-btn" onclick="bmShowPanel(1)">← Back</button>
            <button class="bm-next-btn" onclick="bmBuildSummary(); bmShowPanel(3)">Next: Review →</button>
          </div>
        </div>

        <!-- Panel 3: Confirm -->
        <div class="bm-panel" id="bmPanel3">
          <p class="bm-label">Review & confirm</p>
          <div class="bm-summary-box" id="bmSummaryBox"></div>
          <div class="bm-breakdown" id="bmBreakdown"></div>
          <button type="button" class="bm-btn" id="bmConfirmBtn" onclick="bmSubmit()">✔ Confirm Booking</button>
          <div class="bm-nav-row">
            <button class="bm-back-btn" onclick="bmShowPanel(2)">← Edit guests</button>
          </div>
          <p class="bm-status" id="bmConfirmStatus"></p>
        </div>

        <!-- Success Screen -->
        <div class="bm-success" id="bmSuccess">
          <div class="bm-success-icon">✅</div>
          <h3>Booking confirmed!</h3>
          <p>Your reservation has been submitted.<br />A confirmation will be sent to your email.</p>
          <p class="bm-ref" id="bmRef"></p>
          <button class="bm-btn" onclick="closeBookingModal()" style="max-width: 180px">Close</button>
        </div>
      </div>
    </div>
    <!-- ===== END BOOKING MODAL ===== -->
    <% } %>

    <%- include('../includes/footer.ejs') %>
    <%- include('../includes/chatbot.ejs') %>
    <script src="/js/script.js?v=8"></script>
  </body>
</html>
