<nav class="navbar">
  <a href="/listings" class="navbar-brand">
    <span class="brand-icon">⬡</span>
    <span class="brand-text">Stay<strong>Point</strong></span>
  </a>

  <div class="navbar-links">
    <% if (currUser) { %>
      <a href="/notifications" class="nav-link" style="position: relative; margin-right: 15px; display: inline-flex; align-items: center; justify-content: center;">
        <i class="fa fa-bell" style="font-size: 1.2rem;"></i>
        <% if (unreadNotificationCount > 0) { %>
          <span style="position: absolute; top: -5px; right: -10px; background-color: #e74c3c; color: white; border-radius: 50%; padding: 2px 6px; font-size: 10px; font-weight: bold; border: 2px solid white;"><%= unreadNotificationCount %></span>
        <% } %>
      </a>
      <span class="nav-user">
        <i class="fa fa-user-circle"></i> <%= currUser.username %>
      </span>
      <% if (currUser.role === 'host' || currUser.role === 'admin') { %>
        <a href="/listings/new" class="btn btn-outline">+ List Your Room</a>
        <form action="/profile/switch-role" method="POST" style="display:inline;">
          <input type="hidden" name="_token" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn btn-ghost">Switch to Guest</button>
        </form>
      <% } else { %>
        <form action="/profile/switch-role" method="POST" style="display:inline;">
          <input type="hidden" name="_token" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn btn-outline">Become a Host</button>
        </form>
      <% } %>
      <a href="/logout" class="btn btn-ghost">Logout</a>
    <% } else { %>
      <a href="/login" class="nav-link">Login</a>
      <a href="/signup" class="btn btn-primary">Sign Up</a>
    <% } %>
    <button id="themeToggle" class="btn btn-ghost" style="font-size: 1.2rem; padding: 5px 10px; margin-left: 10px;" title="Toggle dark mode">
      <i class="fa fa-moon"></i>
    </button>
  </div>

  <button class="mobile-menu-btn" id="menuBtn">
    <i class="fa fa-bars"></i>
  </button>

  <div class="mobile-menu" id="mobileMenu">
    <% if (currUser) { %>
      <a href="/notifications" style="position: relative; display: inline-block; width: max-content;">
        Notifications
        <% if (unreadNotificationCount > 0) { %>
          <span style="background-color: #e74c3c; color: white; border-radius: 50%; padding: 2px 8px; font-size: 12px; font-weight: bold; margin-left: 5px;"><%= unreadNotificationCount %></span>
        <% } %>
      </a>
      <span class="nav-user"><i class="fa fa-user-circle"></i> <%= currUser.username %></span>
      <% if (currUser.role === 'host' || currUser.role === 'admin') { %>
        <a href="/listings/new">+ List Your Room</a>
        <form action="/profile/switch-role" method="POST" style="margin: 10px 0;">
          <input type="hidden" name="_token" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" style="background:none; border:none; color:inherit; font:inherit; cursor:pointer; padding:0;">Switch to Guest</button>
        </form>
      <% } else { %>
        <form action="/profile/switch-role" method="POST" style="margin: 10px 0;">
          <input type="hidden" name="_token" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" style="background:none; border:none; color:inherit; font:inherit; cursor:pointer; padding:0;">Become a Host</button>
        </form>
      <% } %>
      <a href="/logout">Logout</a>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/signup">Sign Up</a>
    <% } %>
    <button id="mobileThemeToggle" style="background:none; border:none; color:inherit; font:inherit; cursor:pointer; padding:0; margin-top: 10px; text-align: left;">
      <i class="fa fa-moon"></i> Toggle Dark Mode
    </button>
  </div>
</nav>
