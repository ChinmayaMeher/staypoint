<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StayPoint - Error</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
  </head>
  <body>
    <main>
      <div class="error-page">
        <div class="error-content">
          <div class="error-code"><%= error.status || 500 %></div>
          <h2 class="error-title"><%= message %></h2>
          <p class="error-desc">Something went wrong. Please try again.</p>
          <a href="/listings" class="btn btn-primary">
            <i class="fa fa-home"></i> Back to Home
          </a>
        </div>
      </div>
    </main>
  </body>
</html>
