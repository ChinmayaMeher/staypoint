<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>StayPoint - Edit Listing</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
</head>
<body>
  <%- include('../includes/navbar.ejs') %>

  <div class="flash-container">
    <% if (success && success.length) { %>
      <div class="flash flash-success">
        <i class="fa fa-check-circle"></i> <%= success %>
        <button class="flash-close" onclick="this.parentElement.remove()">×</button>
      </div>
    <% } %>
    <% if (error && error.length) { %>
      <div class="flash flash-error">
        <i class="fa fa-exclamation-circle"></i> <%= error %>
        <button class="flash-close" onclick="this.parentElement.remove()">×</button>
      </div>
    <% } %>
  </div>

  <main>
    <div class="form-page">
      <div class="form-card">
        <div class="form-card-header">
          <h2><i class="fa fa-edit"></i> Edit Listing</h2>
          <p>Update your room details</p>
        </div>

        <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" class="listing-form">
          <div class="form-grid">
            <div class="form-group span-2">
              <label for="title">Listing Title *</label>
              <input type="text" id="title" name="listing[title]" class="form-control"
                value="<%= listing.title %>" required />
            </div>

            <div class="form-group span-2">
              <label for="description">Description</label>
              <textarea id="description" name="listing[description]" class="form-control" rows="4"><%= listing.description || '' %></textarea>
            </div>

            <div class="form-group span-2">
              <label for="image">Image URL</label>
              <input type="url" id="image" name="listing[image]" class="form-control"
                value="<%= listing.image %>" />
            </div>

            <div class="form-group">
              <label for="price">Price per Night (₹) *</label>
              <input type="number" id="price" name="listing[price]" class="form-control"
                value="<%= listing.price %>" min="1" required />
            </div>

            <div class="form-group">
              <label for="rooms">Number of Rooms</label>
              <input type="number" id="rooms" name="listing[rooms]" class="form-control"
                value="<%= listing.rooms || 1 %>" min="1" />
            </div>

            <div class="form-group">
              <label for="category">Category *</label>
              <select id="category" name="listing[category]" class="form-control" required>
                <option value="Apartment" <%= listing.category === 'Apartment' ? 'selected' : '' %>>Apartment</option>
                <option value="House" <%= listing.category === 'House' ? 'selected' : '' %>>House</option>
                <option value="Villa" <%= listing.category === 'Villa' ? 'selected' : '' %>>Villa</option>
                <option value="Cabin" <%= listing.category === 'Cabin' ? 'selected' : '' %>>Cabin</option>
                <option value="Studio" <%= listing.category === 'Studio' ? 'selected' : '' %>>Studio</option>
                <option value="Hostel" <%= listing.category === 'Hostel' ? 'selected' : '' %>>Hostel</option>
              </select>
            </div>

            <div class="form-group">
              <label for="location">City / Area *</label>
              <input type="text" id="location" name="listing[location]" class="form-control"
                value="<%= listing.location %>" required />
            </div>

            <div class="form-group">
              <label for="country">Country *</label>
              <input type="text" id="country" name="listing[country]" class="form-control"
                value="<%= listing.country %>" required />
            </div>

            <div class="form-group span-2">
              <label for="amenities">Amenities</label>
              <input type="text" id="amenities" name="listing[amenities]" class="form-control"
                value="<%= listing.amenities ? listing.amenities.join(', ') : '' %>"
                placeholder="WiFi, AC, Parking (comma separated)" />
            </div>
          </div>

          <div class="form-actions">
            <a href="/listings/<%= listing._id %>" class="btn btn-ghost">Cancel</a>
            <button type="submit" class="btn btn-primary">
              <i class="fa fa-save"></i> Save Changes
            </button>
          </div>
        </form>
      </div>
    </div>
  </main>

  <%- include('../includes/footer.ejs') %>
  <script src="/js/script.js"></script>
</body>
</html>
